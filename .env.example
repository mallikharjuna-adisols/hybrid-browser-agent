NODE_ENV=development

NEXT_PUBLIC_APP_NAME=Orbit Control
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PUBLIC_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000

PORT=4000
APP_URL=http://localhost:3000
