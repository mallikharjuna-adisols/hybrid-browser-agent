{
  "name": "orbit-enterprise-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Production-ready AI SaaS monorepo with Next.js, Express, Postgres, Playwright workers, MCP bridge, and Docker deployment.",
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @orbit/web",
    "dev:api": "npm run dev --workspace @orbit/api",
    "dev:worker": "npm run dev --workspace @orbit/worker-playwright",
    "build:web": "npm run build --workspace @orbit/web",
    "start:web": "npm run start --workspace @orbit/web",
    "start:api": "npm run start --workspace @orbit/api",
    "start:worker": "npm run start --workspace @orbit/worker-playwright",
    "lint:web": "npm run lint --workspace @orbit/web"
  }
}
